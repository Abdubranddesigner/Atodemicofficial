rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && incoming().keys().hasAll(['uid', 'email'])
                    && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId)
                    && incoming().uid == existing().uid;
      allow delete: if false;
    }

    // --- Subjects Collection ---
    match /subjects/{subjectId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(subjectId)
                    && incoming().userId == request.auth.uid
                    && incoming().name is string && incoming().name.size() <= 100;
                    
      allow update: if isSignedIn() && isValidId(subjectId)
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().name is string && incoming().name.size() <= 100;
                    
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(taskId)
                    && incoming().userId == request.auth.uid
                    && incoming().title is string && incoming().title.size() <= 200;
                    
      allow update: if isSignedIn() && isValidId(taskId)
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().title is string && incoming().title.size() <= 200;
                    
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- Study Logs Collection ---
    match /study_logs/{logId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(logId)
                    && incoming().userId == request.auth.uid
                    && incoming().durationMinutes is number;
                    
      allow update: if isSignedIn() && isValidId(logId)
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().durationMinutes is number;
                    
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- Quizzes Collection ---
    match /quizzes/{quizId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(quizId)
                    && incoming().userId == request.auth.uid
                    && incoming().score is number;
                    
      allow update: if isSignedIn() && isValidId(quizId)
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId
                    && incoming().score is number;
                    
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- AI Readiness Analyses ---
    match /readiness_analyses/{analysisId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(analysisId)
                    && incoming().userId == request.auth.uid;
                    
      allow update: if isSignedIn() && isValidId(analysisId)
                    && existing().userId == request.auth.uid
                    && incoming().userId == existing().userId;
                    
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}

